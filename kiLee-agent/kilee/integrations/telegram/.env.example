# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=replace-with-bot-token

# DeepSeek Runtime (for telemetry / compatibility; actual calls go to kiLee core)
DEEPSEEK_RUNTIME_URL=http://127.0.0.1:7878
DEEPSEEK_RUNTIME_TOKEN=replace-with-long-random-token
DEEPSEEK_WORKSPACE=/root
DEEPSEEK_MODEL=auto
DEEPSEEK_MODE=agent
DEEPSEEK_ALLOW_SHELL=true
DEEPSEEK_TRUST_MODE=false
DEEPSEEK_AUTO_APPROVE=true

# Security
TELEGRAM_CHAT_ALLOWLIST=
DEEPSEEK_ALLOW_UNLISTED=false
TELEGRAM_OWNER_ID=

# Thread state path
TELEGRAM_THREAD_MAP_PATH=/var/lib/deepseek-telegram-bridge/thread-map.json

# Limits
TELEGRAM_MAX_REPLY_CHARS=4000
DEEPSEEK_TURN_TIMEOUT_MS=900000
